#let base-color = rgb("#00ffd9")
#let title-color = rgb("#ff8000")

#let header-above = 0%
#let header-below = 15%

#let page-bg = gradient.linear(
    (rgb("#daffe3"), 0%),
    (rgb("#c2ffd7"), 25%),
    (rgb("#97f6ff"), 100%),
    angle: 50deg,
)

#let title-page-bg = gradient.linear(
    (rgb("#fffdda"), 0%),
    (rgb("#f3ffc2"), 25%),
    (rgb("#ffc297"), 100%),
    angle: 50deg,
)

#let page-margin = 10%

#let font-size = 2em
#let header-font-size = 1.5em
#let title-font-size = 1.7em

#let margin-color = rgb("#006aff70")
#let margin-text-size = 0.5em
#let margin-font = "Hack"

#let numbering-color = rgb("#000000a0")
#let numbering-text-size = 1em

#let watermark-color = rgb("#00000010")
#let watermark-text-size = 2em
#let watermark-font = "Balsamiq Sans"
#let watermark-rotation = -10deg
